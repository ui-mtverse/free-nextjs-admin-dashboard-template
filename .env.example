# Helios Pro Environment Variables
# Copy this file to .env.local for local development.

# Required for production auth
# Generate a secret with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-32-char-random-secret"

# Public URL of your deployed app, no trailing slash
# Local dev: http://localhost:3000
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Database connection string
# Example format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@host:5432/helios_pro?sslmode=require"

# Optional Google OAuth for social login
# Leave blank to disable social login.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Demo mode
# If auth/database values are not configured, Helios Pro pages can still render with mock data for UI preview.
